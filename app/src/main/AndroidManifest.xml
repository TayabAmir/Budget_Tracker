<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools" >

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Budget_Tracker" >

        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.Budget_Tracker.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.Budget_Tracker.NoActionBar" />

        <activity
            android:name=".SignInActivity"
            android:exported="false"
            android:label="@string/sign_in_title"
            android:theme="@style/Theme.Budget_Tracker" />

        <activity
            android:name=".SignUpActivity"
            android:exported="false"
            android:label="@string/sign_up_title"
            android:theme="@style/Theme.Budget_Tracker" />

        <activity
            android:name=".AddExpenseActivity"
            android:exported="false"
            android:label="Add Expense"
            android:theme="@style/Theme.Budget_Tracker" />

        <activity
            android:name=".AddSubscriptionActivity"
            android:exported="false"
            android:label="@string/add_subscription_title"
            android:theme="@style/Theme.Budget_Tracker" />

        <activity
            android:name=".AddSavingsGoalActivity"
            android:exported="false"
            android:label="@string/add_savings_goal_title"
            android:theme="@style/Theme.Budget_Tracker" />

        <receiver android:name=".NotificationReceiver" android:exported="false" />

    </application>

</manifest>
